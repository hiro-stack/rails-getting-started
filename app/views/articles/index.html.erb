<h1 class="page-title">Blog</h1>

<p class="article-count">
  Our blog has <%= Article.public_count %> articles and counting!
</p>


<div class="search-form-container">
  <p>記事の検索</p>
  <%= search_form_for @q, url: articles_path, html: { class: "search-form" } do |f| %>
    <div class="form-group">
      <%= f.label :title_or_body_cont, "タイトル" %>
      <%= f.search_field :title_or_body_cont, class: 'form-control', placeholder: '検索ワード' %>
    </div>

    <div class="form-group">
      <%= f.label :body_cont, "本文" %> <!-- bodyだけで検索したい場合 -->
      <%= f.search_field :body_cont, class: 'form-control', placeholder: '本文検索' %>
    </div>

    <div class="form-actions">
      <%= f.submit '検索', class: 'btn btn-primary' %>
    </div>
  <% end %>
</div>

<div class="new-article-link">
  <%= link_to "新しい記事の作成", new_article_path, class: "btn btn-success" %>
</div>

<h2 class="search-results-title">Articles</h2>

<div class="articles-list">
  <% @articles.each do |article| %>
    <div class="article-item">
      <h4 class="article-create-time"><%= article.created_at %></h4>
      <h3 class="article-title">
        <%= link_to article.title, article_path(article) %>
      </h3>
      <p class="article-body"><%= article.body %></p>
    </div>
  <% end %>
</div>

